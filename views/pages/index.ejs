<!DOCTYPE html>
<html lang="es">

<head>

    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0">

    <title>
        Camisetas del Mundo
    </title>

    <link
        rel="stylesheet"
        href="/css/styles.css">

</head>

<body>

    <%- include("../partials/header") %>

    <!-- CONTENIDO -->

    <main class="container">

        <!-- SIDEBAR -->

        <aside class="sidebar">

            <div class="sidebar-top">

                <h3>
                    Filtros
                </h3>

                <button
                    id="clearFiltersBtn"
                    class="clear-filters-btn">

                    Limpiar

                </button>

            </div>

            <!-- TALLES -->

            <div class="filter-group">

                <button
                    class="filter-toggle">

                    Talles

                    <span>+</span>

                </button>

                <div class="filter-content">

                    <label><input type="checkbox" class="filter-size" value="XS"> XS</label>
                    <label><input type="checkbox" class="filter-size" value="S"> S</label>
                    <label><input type="checkbox" class="filter-size" value="M"> M</label>
                    <label><input type="checkbox" class="filter-size" value="L"> L</label>
                    <label><input type="checkbox" class="filter-size" value="XL"> XL</label>
                    <label><input type="checkbox" class="filter-size" value="XXL"> XXL</label>

                </div>

            </div>

            <!-- INDUMENTARIA -->

            <div class="filter-group">

                <button
                    class="filter-toggle">

                    Indumentaria

                    <span>+</span>

                </button>

                <div class="filter-content">

                    <label><input type="checkbox" class="filter-type" value="Camiseta"> Camiseta</label>
                    <label><input type="checkbox" class="filter-type" value="Short"> Short</label>
                    <label><input type="checkbox" class="filter-type" value="Pantalon"> Pantalon</label>
                    <label><input type="checkbox" class="filter-type" value="Campera"> Campera</label>
                    <label><input type="checkbox" class="filter-type" value="Buzo"> Buzo</label>
                    <label><input type="checkbox" class="filter-type" value="Conjunto"> Conjunto</label>

                </div>

            </div>

            <!-- CLUBES -->

            <div class="filter-group">

                <button
                    class="filter-toggle">

                    Clubes

                    <span>+</span>

                </button>

                <div class="filter-content">

                    <label><input type="checkbox" class="filter-team" value="Boca"> Boca</label>
                    <label><input type="checkbox" class="filter-team" value="River"> River</label>
                    <label><input type="checkbox" class="filter-team" value="Barcelona"> Barcelona</label>
                    <label><input type="checkbox" class="filter-team" value="Real Madrid"> Real Madrid</label>

                </div>

            </div>

            <!-- SELECCIONES -->

            <div class="filter-group">

                <button
                    class="filter-toggle">

                    Selecciones

                    <span>+</span>

                </button>

                <div class="filter-content">

                    <label><input type="checkbox" class="filter-team" value="Argentina"> Argentina</label>
                    <label><input type="checkbox" class="filter-team" value="Brasil"> Brasil</label>
                    <label><input type="checkbox" class="filter-team" value="Francia"> Francia</label>

                </div>

            </div>

        </aside>

        <!-- PRODUCTOS -->

        <section class="products-section">

            <div class="products-topbar">

                <h2>
                    Productos
                </h2>

                <select id="sortSelect">

                    <option value="recent">
                        Más recientes
                    </option>

                    <option value="low">
                        Menor precio
                    </option>

                    <option value="high">
                        Mayor precio
                    </option>

                    <option value="featured">
                        Destacados
                    </option>

                </select>

            </div>

            <div
                id="noResults"
                class="no-results">

                No se encontraron productos.

            </div>

            <div
                class="products"
                id="productsGrid">

                <% productos.forEach(producto => { %>

                    <article
                        class="product-card"

                        data-id="<%= producto.id %>"

                        data-price="<%= producto.precio %>"

                        data-featured="<%= producto.destacado %>"

                        data-equipo="<%= producto.equipo %>"

                        data-categoria="<%= producto.categoria %>"

                        data-stock='<%- JSON.stringify(producto.stock || {}) %>'>

                        <% if(producto.nuevo){ %>

                            <span class="product-badge badge-new">

                                NUEVO

                            </span>

                        <% } %>

                        <% if(producto.oferta){ %>

                            <span class="product-badge badge-sale">

                                OFERTA

                            </span>

                        <% } %>

                        <% if(producto.destacado){ %>

                            <span class="product-badge badge-featured">

                                DESTACADO

                            </span>

                        <% } %>

                        <a
                            href="/producto/<%= producto.id %>"
                            class="product-link">

                            <% if(producto.imagenes && producto.imagenes[0]){ %>

                                <img
                                    src="<%= producto.imagenes[0] %>"
                                    alt="<%= producto.nombre %>">

                            <% } else { %>

                                <div class="product-image-placeholder">

                                    ⚽

                                </div>

                            <% } %>

                            <div class="product-info-card">

                                <h3>
                                    <%= producto.nombre %>
                                </h3>

                                <p class="price">

                                    $<%= producto.precio.toLocaleString("es-AR") %>

                                </p>

                                <button class="view-product-btn">

                                    Ver producto

                                </button>

                            </div>

                        </a>

                    </article>

                <% }) %>

            </div>

        </section>

    </main>

    <%- include("../partials/footer") %>

    <script src="/js/main.js"></script>

</body>

</html>

