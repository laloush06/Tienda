<!DOCTYPE html>
<html lang="es">

<head>

    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0">

    <title>
        Admin
    </title>

    <link
        rel="stylesheet"
        href="/css/styles.css">

</head>

<body>

    <%
        const editar =
            typeof productoEditar !== "undefined"
            &&
            productoEditar;
    %>

    <%- include("../partials/header") %>

    <div class="cart-page">

        <div class="products-topbar">

            <h1>

                Panel Admin

            </h1>

        </div>

        <!-- FORM -->

        <form

            class="admin-form"

            action="<%= editar ? '/admin/editar/' + editar.id : '/admin/crear' %>"

            method="POST"

            enctype="multipart/form-data">

            <!-- NOMBRE -->

            <input
                type="text"
                name="nombre"
                placeholder="Nombre"
                required
                value="<%= editar ? editar.nombre : '' %>">

            <!-- PRECIO ORIGINAL -->

            <input
                type="number"
                name="precioOriginal"
                placeholder="Precio original"
                required
                value="<%= editar ? editar.precioOriginal || editar.precio : '' %>">

            <!-- PRECIO OFERTA -->

            <input
                type="number"
                name="precioOferta"
                placeholder="Precio oferta"
                value="<%= editar ? editar.precioOferta || '' : '' %>">

            <!-- EQUIPO -->

            <select
                name="equipo"
                required>

                <option value="">
                    Equipo / Selección
                </option>

                <% [
                    "Boca",
                    "River",
                    "Barcelona",
                    "Real Madrid",
                    "Argentina",
                    "Brasil",
                    "Francia"
                ].forEach(equipo => { %>

                    <option
                        value="<%= equipo %>"
                        <%= editar && editar.equipo === equipo ? 'selected' : '' %>>

                        <%= equipo %>

                    </option>

                <% }) %>

            </select>

            <!-- CATEGORIA -->

            <select
                name="categoria"
                required>

                <option value="">
                    Categoría
                </option>

                <% [
                    "Camiseta",
                    "Short",
                    "Pantalon",
                    "Campera",
                    "Buzo",
                    "Conjunto"
                ].forEach(cat => { %>

                    <option
                        value="<%= cat %>"
                        <%= editar && editar.categoria === cat ? 'selected' : '' %>>

                        <%= cat %>

                    </option>

                <% }) %>

            </select>

            <!-- DESCRIPCION -->

            <textarea
                name="descripcion"
                placeholder="Descripción"
                class="admin-description"
                required><%= editar ? editar.descripcion : '' %></textarea>

            <!-- STOCK -->

            <div class="admin-stock-wrapper">

                <h3>

                    Stock por talle

                </h3>

                <div class="admin-stock-grid">

                    <% [
                        "XS",
                        "S",
                        "M",
                        "L",
                        "XL",
                        "XXL"
                    ].forEach(talle => { %>

                        <div class="stock-item">

                            <label class="stock-title">

                                <%= talle %>

                            </label>

                            <div class="stock-controls">

                                <button
                                    type="button"
                                    class="stock-btn"
                                    onclick="
                                        cambiarStock(
                                            'stock<%= talle %>',
                                            -1
                                        )
                                    ">

                                    -

                                </button>

                                <input

                                    type="number"

                                    id="stock<%= talle %>"

                                    name="stock<%= talle %>"

                                    class="stock-input"

                                    min="0"

                                    value="<%= editar && editar.stock ? editar.stock[talle] || 0 : 0 %>">

                                <button
                                    type="button"
                                    class="stock-btn"
                                    onclick="
                                        cambiarStock(
                                            'stock<%= talle %>',
                                            1
                                        )
                                    ">

                                    +

                                </button>

                            </div>

                        </div>

                    <% }) %>

                </div>

            </div>

            <!-- BADGES -->

            <div class="admin-badges">

                <label>

                    <input
                        type="checkbox"
                        name="nuevo"
                        <%= editar && editar.nuevo ? 'checked' : '' %>>

                    Nuevo

                </label>

                <label>

                    <input
                        type="checkbox"
                        name="destacado"
                        <%= editar && editar.destacado ? 'checked' : '' %>>

                    Destacado

                </label>

            </div>

            <!-- IMAGENES -->


            <div class="admin-upload-container">

                <label class="custom-upload">

                    <span>
                        Seleccionar imágenes
                    </span>

                    <input
                        type="file"
                        name="imagenes"
                        id="imagenesInput"
                        multiple
                        accept="image/*">

                </label>

                <div
                    id="previewContainer"
                    class="preview-container">

                </div>

            </div>

            <!-- BOTON -->

            <button type="submit">

                <%= editar
                    ? 'Guardar cambios'
                    : 'Agregar producto' %>

            </button>

        </form>

        <!-- PRODUCTOS -->

        <div class="cart-container">

            <% productos.forEach(producto => { %>

                <div class="cart-item">

                    <div class="admin-product-left">

                        <img
                            src="<%= producto.imagenes[0] %>"
                            class="admin-product-image">

                        <div>

                            <h2>

                                <%= producto.nombre %>

                            </h2>

                            <p>

                                $<%= producto.precio.toLocaleString("es-AR") %>

                            </p>

                        </div>

                    </div>

                    <div class="admin-buttons">

                        <a
                            href="/producto/<%= producto.id %>"
                            class="go-cart-btn">

                            Ver

                        </a>

                        <a
                            href="/admin/editar/<%= producto.id %>"
                            class="go-cart-btn">

                            Editar

                        </a>

                        <form
                            action="/admin/eliminar/<%= producto.id %>"
                            method="POST">

                            <button
                                class="remove-btn">

                                Eliminar

                            </button>

                        </form>

                    </div>

                </div>

            <% }) %>

        </div>

    </div>

    <script>

        function cambiarStock(id,cambio){

            const input =
                document.getElementById(id);

            let valor =
                Number(input.value);

            valor += cambio;

            if(valor < 0){

                valor = 0;

            }

            input.value = valor;

        }

    </script>

    <script>

    const imagenesInput =
        document.getElementById(
            "imagenesInput"
        );

    const previewContainer =
        document.getElementById(
            "previewContainer"
        );

    imagenesInput.addEventListener(
        "change",
        () => {

            previewContainer.innerHTML = "";

            const files =
                imagenesInput.files;

            for(const file of files){

                const reader =
                    new FileReader();

                reader.onload =
                    e => {

                        const img =
                            document.createElement(
                                "img"
                            );

                        img.src =
                            e.target.result;

                        img.classList.add(
                            "preview-image"
                        );

                        previewContainer.appendChild(
                            img
                        );

                    };

                reader.readAsDataURL(
                    file
                );

            }

        }
    );

    </script>


</body>

</html>

