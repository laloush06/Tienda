<!DOCTYPE html>
<html lang="es">

<head>

    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0">

    <title>
        Admin
    </title>

    <link
        rel="stylesheet"
        href="/css/styles.css">

</head>

<body>

    <%
        const editar =
            typeof productoEditar !== "undefined"
            &&
            productoEditar;
    %>

    <%- include("../partials/header") %>

    <div class="cart-page">

        <!-- TOP -->

        <div class="products-topbar">

            <h1>

                Panel Admin

            </h1>

            <a
                href="/logout"
                class="go-cart-btn"
                style="
                    width:auto;
                    padding:14px 20px;
                ">

                Logout

            </a>

        </div>

        <!-- FORM -->

        <form

            class="admin-form"

            action="<%= editar ? '/admin/editar/' + editar.id : '/admin/crear' %>"

            method="POST"

            enctype="multipart/form-data">

            <!-- NOMBRE -->

            <input
                type="text"
                name="nombre"
                placeholder="Nombre"
                required

                value="<%= editar ? editar.nombre : '' %>">

            <!-- PRECIO -->

            <input
                type="number"
                name="precio"
                placeholder="Precio"
                required

                value="<%= editar ? editar.precio : '' %>">

            <!-- EQUIPO -->

            <select
                name="equipo"
                required>

                <option value="">
                    Equipo / Selección
                </option>

                <% [
                    "Boca",
                    "River",
                    "Barcelona",
                    "Real Madrid",
                    "Argentina",
                    "Brasil",
                    "Francia"
                ].forEach(equipo => { %>

                    <option

                        value="<%= equipo %>"

                        <%= editar &&
                            editar.equipo === equipo
                            ? 'selected'
                            : '' %>>

                        <%= equipo %>

                    </option>

                <% }) %>

            </select>

            <!-- CATEGORIA -->

            <select
                name="categoria"
                required>

                <option value="">
                    Categoría
                </option>

                <% [
                    "Camiseta",
                    "Short",
                    "Pantalon",
                    "Campera",
                    "Buzo",
                    "Conjunto"
                ].forEach(cat => { %>

                    <option

                        value="<%= cat %>"

                        <%= editar &&
                            editar.categoria === cat
                            ? 'selected'
                            : '' %>>

                        <%= cat %>

                    </option>

                <% }) %>

            </select>

            <!-- DESCRIPCION -->

            <textarea

                name="descripcion"

                placeholder="Descripción del producto"

                class="admin-description"

                required><%= editar ? editar.descripcion : '' %></textarea>

            <!-- TALLES -->

            <div class="admin-talles">

                <h3>
                    Talles
                </h3>

                <div class="admin-talles-grid">

                    <% [
                        "XS",
                        "S",
                        "M",
                        "L",
                        "XL",
                        "XXL"
                    ].forEach(talle => { %>

                        <label>

                            <input
                                type="checkbox"
                                name="talles"
                                value="<%= talle %>"

                                <%= editar &&
                                    editar.talles.includes(talle)
                                    ? 'checked'
                                    : '' %>>

                            <%= talle %>

                        </label>

                    <% }) %>

                </div>

            </div>

            <!-- BADGES -->

            <div class="admin-badges">

                <label>

                    <input
                        type="checkbox"
                        name="nuevo"

                        <%= editar &&
                            editar.nuevo
                            ? 'checked'
                            : '' %>>

                    Nuevo

                </label>

                <label>

                    <input
                        type="checkbox"
                        name="oferta"

                        <%= editar &&
                            editar.oferta
                            ? 'checked'
                            : '' %>>

                    Oferta

                </label>

                <label>

                    <input
                        type="checkbox"
                        name="destacado"

                        <%= editar &&
                            editar.destacado
                            ? 'checked'
                            : '' %>>

                    Destacado

                </label>

            </div>

            <!-- IMAGENES -->

            <div class="admin-upload-container">

                <label class="custom-upload">

                    Seleccionar imágenes

                    <input
                        type="file"
                        name="imagenes"
                        multiple
                        hidden>

                </label>

            </div>

            <!-- BOTON -->

            <button type="submit">

                <%= editar
                    ? 'Guardar cambios'
                    : 'Agregar producto' %>

            </button>

        </form>

        <!-- PRODUCTOS -->

        <div class="cart-container">

            <% productos.forEach(producto => { %>

                <div class="cart-item">

                    <!-- IZQUIERDA -->

                    <div class="admin-product-left">

                        <img
                            src="<%= producto.imagenes[0] %>"
                            class="admin-product-image">

                        <div>

                            <h2>

                                <%= producto.nombre %>

                            </h2>

                            <p>

                                $<%= producto.precio.toLocaleString("es-AR") %>

                            </p>

                            <p>

                                <%= producto.categoria %>

                            </p>

                        </div>

                    </div>

                    <!-- BOTONES -->

                    <div class="admin-buttons">

                        <!-- EDITAR -->

                        <a

                            href="/admin/editar/<%= producto.id %>"

                            class="go-cart-btn">

                            Editar

                        </a>

                        <!-- ELIMINAR -->

                        <form

                            action="/admin/eliminar/<%= producto.id %>"

                            method="POST"

                            onsubmit="
                                return confirm(
                                    '¿Eliminar producto?'
                                )
                            ">

                            <button
                                class="remove-btn">

                                Eliminar

                            </button>

                        </form>

                    </div>

                </div>

            <% }) %>

        </div>

    </div>

</body>

</html>