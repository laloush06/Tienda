<!DOCTYPE html>
<html lang="es">

<head>

    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0">

    <title>
        Admin
    </title>

    <link
        rel="stylesheet"
        href="/css/styles.css">

</head>

<body>

    <%
        const editar =
            typeof productoEditar !== "undefined"
            &&
            productoEditar;
    %>

    <%- include("../partials/header") %>

    <div class="cart-page">

        <div class="products-topbar">

            <h1>

                Panel Admin

            </h1>

        </div>

        <!-- =========================
             IMPORTAR EXCEL
        ========================= -->

        <form
            action="/admin/importar"
            method="POST"
            enctype="multipart/form-data"
            class="excel-import-form">

            <h2>

                Importar productos Excel

            </h2>

            <p>

                Subí un archivo .xlsx con productos y stock

            </p>

            <input
                type="file"
                name="excel"
                accept=".xlsx,.xls"
                required>

            <button type="submit">

                Importar Excel

            </button>

        </form>

        <!-- =========================
             FORM
        ========================= -->

        <form

            class="admin-form"

            action="<%= editar ? '/admin/editar/' + editar.id : '/admin/crear' %>"

            method="POST"

            enctype="multipart/form-data">

            <!-- NOMBRE -->

            <input
                type="text"
                name="nombre"
                placeholder="Nombre"
                required
                value="<%= editar ? editar.nombre : '' %>">

            <!-- PRECIO ORIGINAL -->

            <input
                type="number"
                name="precioOriginal"
                placeholder="Precio original"
                required
                value="<%= editar ? editar.precioOriginal || editar.precio : '' %>">

            <!-- PRECIO OFERTA -->

            <input
                type="number"
                name="precioOferta"
                placeholder="Precio oferta"
                value="<%= editar ? editar.precioOferta || '' : '' %>">

            <!-- EQUIPO -->

            <select
                name="equipo"
                required>

                <option value="">
                    Equipo / Selección
                </option>

                <% [
                    "Boca",
                    "River",
                    "Barcelona",
                    "Real Madrid",
                    "Argentina",
                    "Brasil",
                    "Francia"
                ].forEach(equipo => { %>

                    <option
                        value="<%= equipo %>"
                        <%= editar && editar.equipo === equipo ? 'selected' : '' %>>

                        <%= equipo %>

                    </option>

                <% }) %>

            </select>

            <!-- CATEGORIA -->

            <select
                name="categoria"
                required>

                <option value="">
                    Categoría
                </option>

                <% [
                    "Camiseta",
                    "Short",
                    "Pantalon",
                    "Campera",
                    "Buzo",
                    "Conjunto"
                ].forEach(cat => { %>

                    <option
                        value="<%= cat %>"
                        <%= editar && editar.categoria === cat ? 'selected' : '' %>>

                        <%= cat %>

                    </option>

                <% }) %>

            </select>

            <!-- DESCRIPCION -->

            <textarea
                name="descripcion"
                placeholder="Descripción"
                class="admin-description"
                required><%= editar ? editar.descripcion : '' %></textarea>

            <!-- =========================
                 STOCK
            ========================= -->

            <div class="admin-stock-wrapper">

                <h3>

                    Stock por talle

                </h3>

                <div class="admin-stock-grid">

                    <% [
                        "XS",
                        "S",
                        "M",
                        "L",
                        "XL",
                        "XXL"
                    ].forEach(talle => { %>

                        <div class="stock-item">

                            <label class="stock-title">

                                <%= talle %>

                            </label>

                            <div class="stock-controls">

                                <button
                                    type="button"
                                    class="stock-btn"
                                    onclick="
                                        cambiarStock(
                                            'stock<%= talle %>',
                                            -1
                                        )
                                    ">

                                    -

                                </button>

                                <input

                                    type="number"

                                    id="stock<%= talle %>"

                                    name="stock<%= talle %>"

                                    class="stock-input"

                                    min="0"

                                    value="<%= editar && editar.stock ? editar.stock[talle] || 0 : 0 %>">

                                <button
                                    type="button"
                                    class="stock-btn"
                                    onclick="
                                        cambiarStock(
                                            'stock<%= talle %>',
                                            1
                                        )
                                    ">

                                    +

                                </button>

                            </div>

                        </div>

                    <% }) %>

                </div>

            </div>

            <!-- =========================
                 BADGES
            ========================= -->

            <div class="admin-badges">

                <label>

                    <input
                        type="checkbox"
                        name="nuevo"
                        <%= editar && editar.nuevo ? 'checked' : '' %>>

                    Nuevo

                </label>

                <label>

                    <input
                        type="checkbox"
                        name="destacado"
                        <%= editar && editar.destacado ? 'checked' : '' %>>

                    Destacado

                </label>

            </div>

<!-- =========================
     IMAGENES
========================= -->

<div class="image-upload-wrapper">

    <h2>

        Seleccionar imágenes

    </h2>

    <input
        type="hidden"
        id="imagenesExistentes"
        name="imagenesExistentes"
        value='<%= JSON.stringify(
            editar && editar.imagenes
                ? editar.imagenes
                : []
        ) %>'>

    <div class="image-upload-grid">

        <% for(let i = 0; i < 5; i++){ %>

            <label class="image-upload-card">

                <input

                    type="file"

                    name="imagenes"

                    accept="image/*"

                    class="image-input"

                    onchange="previewImage(event, <%= i %>)">

                <div
                    class="image-preview"
                    id="preview-<%= i %>">

                    <% if(
                        editar &&
                        editar.imagenes &&
                        editar.imagenes[i]
                    ){ %>

                        <button
                            type="button"
                            class="delete-image-btn"
                            onclick="eliminarImagen(event, <%= i %>)">

                            ×

                        </button>

                        <img
                            src="<%= editar.imagenes[i] %>"
                            class="preview-img"
                            alt="preview">

                    <% } else { %>

                        <span>

                            +

                        </span>

                        <p>

                            <%= i === 0
                                ? "Portada"
                                : `Imagen ${i + 1}` %>

                        </p>

                    <% } %>

                </div>

            </label>

        <% } %>

    </div>

</div>

            <!-- =========================
                 BOTON
            ========================= -->

            <button type="submit">

                <%= editar
                    ? 'Guardar cambios'
                    : 'Agregar producto' %>

            </button>

        </form>

```ejs
<!-- =========================
     PRODUCTOS
========================= -->

<div class="admin-list">

    <% productos.forEach(producto => { %>

        <div class="admin-row">

            <!-- IMAGEN -->

            <div class="admin-row-image">

                <img
                    src="<%= producto.imagenes[0] %>"
                    alt="<%= producto.nombre %>">

            </div>

            <!-- INFO -->

            <div class="admin-row-info">

                <h3>

                    <%= producto.nombre %>

                </h3>

                <p>

                    $<%= producto.precio.toLocaleString("es-AR") %>

                </p>

            </div>

            <!-- STOCK -->

            <div class="admin-row-stock">

                <% if(producto.stock){ %>

                    <% let total = 0; %>

                    <% producto.stock.forEach(s => { %>

                        <% total += s.cantidad %>

                    <% }) %>

                    <span>

                        Stock:
                        <strong>
                            <%= total %>
                        </strong>

                    </span>

                <% } %>

            </div>

            <!-- ACCIONES -->

            <div class="admin-row-actions">

                <a
                    href="/producto/<%= producto.id %>"
                    class="admin-btn view">

                    Ver

                </a>

                <a
                    href="/admin/editar/<%= producto.id %>"
                    class="admin-btn edit">

                    Editar

                </a>

                <form
                    action="/admin/eliminar/<%= producto.id %>"
                    method="POST">

                    <button
                        class="admin-btn delete">

                        Eliminar

                    </button>

                </form>

            </div>

        </div>

    <% }) %>

</div>


    </div>

<script>

function cambiarStock(id,cambio){

    const input =
        document.getElementById(id);

    let valor =
        Number(input.value);

    valor += cambio;

    if(valor < 0){

        valor = 0;

    }

    input.value = valor;

}

function previewImage(event,index){

    const file =
        event.target.files[0];

    if(!file) return;

    const reader =
        new FileReader();

    reader.onload =
        function(e){

            const preview =
                document.getElementById(
                    `preview-${index}`
                );

            preview.innerHTML = `

                <button
                    type="button"
                    class="delete-image-btn"
                    onclick="eliminarImagen(event, ${index})">

                    ×

                </button>

                <img
                    src="${e.target.result}"
                    class="preview-img"
                    alt="preview">

            `;

        };

    reader.readAsDataURL(file);

}

function eliminarImagen(event,index){

    event.preventDefault();

    let imagenes =
        JSON.parse(
            document.getElementById(
                "imagenesExistentes"
            ).value
        );

    imagenes.splice(index,1);

    document.getElementById(
        "imagenesExistentes"
    ).value =
        JSON.stringify(imagenes);

    actualizarPreviews(imagenes);

}

function actualizarPreviews(imagenes){

    for(let i = 0; i < 5; i++){

        const preview =
            document.getElementById(
                `preview-${i}`
            );

        if(imagenes[i]){

            preview.innerHTML = `

                <button
                    type="button"
                    class="delete-image-btn"
                    onclick="eliminarImagen(event, ${i})">

                    ×

                </button>

                <img
                    src="${imagenes[i]}"
                    class="preview-img"
                    alt="preview">

            `;

        } else {

            preview.innerHTML = `

                <span>

                    +

                </span>

                <p>

                    ${i === 0
                        ? "Portada"
                        : `Imagen ${i + 1}`}

                </p>

            `;

        }

    }

}

</script>

<script>

/* =========================
   GUARDAR SCROLL
========================= */

window.addEventListener(

    "beforeunload",

    ()=>{

        localStorage.setItem(

            "adminScroll",

            window.scrollY

        );

    }

);

/* =========================
   RESTAURAR SCROLL
========================= */

window.addEventListener(

    "load",

    ()=>{

        const scroll =
            localStorage.getItem(
                "adminScroll"
            );

        if(scroll){

            window.scrollTo(
                0,
                Number(scroll)
            );

        }

    }

);

</script>



</body>

</html>
