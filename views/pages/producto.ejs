<!DOCTYPE html>
<html lang="es">

<head>

    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0">

    <title>

        <%= producto.nombre %>

    </title>

    <link
        rel="stylesheet"
        href="/css/styles.css">

</head>

<body>

    <%- include("../partials/header") %>

    <!-- MENU -->

    <nav class="menu">

        <ul>

            <li><a href="/">Inicio</a></li>

            <li><a href="/destacados">Destacados</a></li>

            <li><a href="/ofertas">Ofertas</a></li>

            <li><a href="/nuevos">Nuevos</a></li>

        </ul>

    </nav>

    <!-- PRODUCTO -->

    <section class="product-page-wrapper">

        <div class="product-detail-card">

            <!-- GALERIA -->

            <div class="gallery-wrapper">

                <!-- MINIATURAS -->

                <div class="thumbnails-vertical">

                    <% producto.imagenes.forEach(imagen => { %>

                        <img

                            src="<%= imagen %>"

                            class="thumbnail-image"

                            onclick="
                                cambiarImagen(
                                    '<%= imagen %>'
                                )
                            ">

                    <% }) %>

                </div>

                <!-- IMAGEN PRINCIPAL -->

                <div class="main-image-container">

                    <img

                        id="mainImage"

                        src="<%= producto.imagenes[0] %>"

                        alt="<%= producto.nombre %>"

                        class="main-image">

                </div>

            </div>

            <!-- INFO -->

            <div class="product-info">

                <!-- BADGES -->

                <div class="product-detail-badges">

                    <% if(producto.nuevo){ %>

                        <span class="detail-badge badge-new">

                            NUEVO

                        </span>

                    <% } %>

                    <% if(producto.oferta){ %>

                        <span class="detail-badge badge-sale">

                            OFERTA

                        </span>

                    <% } %>

                    <% if(producto.destacado){ %>

                        <span class="detail-badge badge-featured">

                            DESTACADO

                        </span>

                    <% } %>

                </div>

                <!-- CATEGORIA -->

                <p class="product-category">

                    <%= producto.categoria %>

                </p>

                <!-- TITULO -->

                <h1>

                    <%= producto.nombre %>

                </h1>

                <!-- PRECIO -->

                <p class="product-price">

                    $<%= producto.precio.toLocaleString("es-AR") %>

                </p>

                <!-- DESCRIPCION -->

                <p class="product-description">

                    <%= producto.descripcion || "Sin descripción disponible." %>

                </p>

                <!-- TALLES -->

                <div class="size-section">

                    <h3>

                        Seleccionar talle

                    </h3>

                    <div class="sizes">

                        <% producto.talles.forEach(talle => { %>

                            <button
                                class="size-btn">

                                <%= talle %>

                            </button>

                        <% }) %>

                    </div>

                </div>

                <!-- CANTIDAD -->

                <div class="quantity-section">

                    <h3>

                        Cantidad

                    </h3>

                    <input
                        type="number"
                        id="cantidad"
                        value="1"
                        min="1">

                </div>

                <!-- BOTONES -->

                <div class="product-actions">

                    <button
                        class="buy-btn"
                        id="addToCartBtn">

                        Agregar al carrito

                    </button>

                    <a
                        href="/carrito"
                        class="go-cart-btn">

                        Ir al carrito

                    </a>

                </div>

            </div>

        </div>

    </section>

    <!-- DESCRIPCION COMPLETA -->

    <section class="product-extra-description">

        <h2>

            Descripción del producto

        </h2>

        <p>

            <%= producto.descripcion || "Sin descripción disponible." %>

        </p>

    </section>

    <!-- RELACIONADOS -->

    <section class="related-products-section">

        <div class="products-topbar">

            <h2>

                También te puede interesar

            </h2>

        </div>

        <div class="products">

            <% productos
                .filter(p => p.id !== producto.id)
                .slice(0,4)
                .forEach(relacionado => { %>

                <article class="product-card">

                    <a
                        href="/producto/<%= relacionado.id %>">

                        <img
                            src="<%= relacionado.imagenes[0] %>"
                            alt="<%= relacionado.nombre %>">

                        <div class="product-info-card">

                            <h3>

                                <%= relacionado.nombre %>

                            </h3>

                            <p class="price">

                                $<%= relacionado.precio.toLocaleString("es-AR") %>

                            </p>

                            <button class="view-product-btn">

                                Ver producto

                            </button>

                        </div>

                    </a>

                </article>

            <% }) %>

        </div>

    </section>

    <%- include("../partials/footer") %>

    <script>

        // =========================
        // CAMBIAR IMAGEN
        // =========================

        function cambiarImagen(src){

            document
                .getElementById("mainImage")
                .src = src;

        }

        // =========================
        // TALLES
        // =========================

        let talleSeleccionado = null;

        const sizeButtons =
            document.querySelectorAll(
                ".size-btn"
            );

        sizeButtons.forEach(btn => {

            btn.addEventListener(
                "click",
                () => {

                    sizeButtons.forEach(b =>
                        b.classList.remove(
                            "active-size"
                        )
                    );

                    btn.classList.add(
                        "active-size"
                    );

                    talleSeleccionado =
                        btn.textContent.trim();

                }
            );

        });

        // =========================
        // CARRITO
        // =========================

        const addToCartBtn =
            document.getElementById(
                "addToCartBtn"
            );

        addToCartBtn.addEventListener(
            "click",
            () => {

                if(!talleSeleccionado){

                    alert(
                        "Seleccioná un talle"
                    );

                    return;

                }

                const cantidad =
                    Number(
                        document
                            .getElementById(
                                "cantidad"
                            ).value
                    );

                const productoCarrito = {

                    id:<%= producto.id %>,

                    nombre:`<%= producto.nombre %>`,

                    precio:<%= producto.precio %>,

                    imagen:`<%= producto.imagenes[0] %>`,

                    talle:talleSeleccionado,

                    cantidad

                };

                let cart =
                    JSON.parse(
                        localStorage.getItem(
                            "cart"
                        )
                    ) || [];

                cart.push(
                    productoCarrito
                );

                localStorage.setItem(
                    "cart",
                    JSON.stringify(cart)
                );

                alert(
                    "Producto agregado"
                );

            }
        );

    </script>

</body>

</html>