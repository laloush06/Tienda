<!DOCTYPE html>
<html lang="es">

<head>

    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0">

    <title>

        <%= producto.nombre %>

    </title>

    <link
        rel="stylesheet"
        href="/css/styles.css">

</head>

<body>

    <%- include("../partials/header") %>

    <!-- PRODUCTO -->

    <section class="product-page-wrapper">

        <div class="product-detail-card">

            <!-- GALERIA -->

            <div class="gallery-wrapper">

                <!-- MINIATURAS -->

                <div class="thumbnails-vertical">

                    <% producto.imagenes.forEach(imagen => { %>

                        <img

                            src="<%= imagen %>"

                            class="thumbnail-image"

                            onclick="
                                cambiarImagen(
                                    '<%= imagen %>'
                                )
                            ">

                    <% }) %>

                </div>

                <!-- IMAGEN -->

                <div class="main-image-container">

                    <img

                        id="mainImage"

                        src="<%= producto.imagenes[0] %>"

                        alt="<%= producto.nombre %>"

                        class="main-image">

                </div>

            </div>

            <!-- INFO -->

            <div class="product-info">

                <% if(admin){ %>

                    <a

                        href="/admin/editar/<%= producto.id %>"

                        class="admin-edit-product-btn">

                        Editar producto

                    </a>

                <% } %>

                <!-- BADGES -->

                <div class="product-detail-badges">

                    <% if(producto.nuevo){ %>

                        <span class="detail-badge badge-new">

                            NUEVO

                        </span>

                    <% } %>

                    <% if(producto.oferta){ %>

                        <span class="detail-badge badge-sale">

                            OFERTA

                        </span>

                    <% } %>

                    <% if(producto.destacado){ %>

                        <span class="detail-badge badge-featured">

                            DESTACADO

                        </span>

                    <% } %>

                </div>

                <!-- CATEGORIA -->

                <p class="product-category">

                    <%= producto.categoria %>

                </p>

                <!-- TITULO -->

                <h1>

                    <%= producto.nombre %>

                </h1>

                <!-- PRECIOS -->

                <% if(producto.precioOferta > 0){ %>

                    <div class="product-price-wrapper">

                        <span class="old-price">

                            $<%= producto.precioOriginal.toLocaleString("es-AR") %>

                        </span>

                        <span class="discount-badge">

                            -<%= Math.round(
                                (
                                    (
                                        producto.precioOriginal -
                                        producto.precioOferta
                                    )
                                    /
                                    producto.precioOriginal
                                ) * 100
                            ) %>%

                        </span>

                    </div>

                <% } %>

                <p class="product-price">

                    $<%= producto.precio.toLocaleString("es-AR") %>

                </p>

                <!-- DESCRIPCION -->

                <p class="product-description">

                    <%= producto.descripcion || "Sin descripción disponible." %>

                </p>

                <!-- STOCK -->

                <div
                    id="stockMessage"
                    class="stock-message">

                    Seleccioná un talle

                </div>

                <!-- TALLES -->

                <div class="size-section">

                    <h3>

                        Seleccionar talle

                    </h3>

                    <div class="sizes">

                        <% ["XS","S","M","L","XL","XXL"].forEach(talle => {

                            const stockItem =
                                producto.stock.find(
                                    s => s.talle === talle
                                );

                            const stock =
                                stockItem
                                    ? stockItem.cantidad
                                    : 0;

                            const agotado =
                                stock <= 0;

                        %>

                            <button

                                type="button"

                                class="
                                    size-btn
                                    <%= agotado ? 'disabled-size' : '' %>
                                "

                                data-stock="<%= stock %>"

                                data-size="<%= talle %>"

                                <%= agotado ? 'disabled' : '' %>>

                                <%= talle %>

                            </button>

                        <% }) %>

                    </div>

                </div>

                <!-- CANTIDAD -->

                <div class="quantity-section">

                    <h3>

                        Cantidad

                    </h3>

                    <input
                        type="number"
                        id="cantidad"
                        value="1"
                        min="1">

                </div>

                <!-- BOTONES -->

                <div class="product-actions">

                    <button
                        class="buy-btn"
                        id="addToCartBtn">

                        Agregar al carrito

                    </button>

                    <a
                        href="/carrito"
                        class="go-cart-btn">

                        Ir al carrito

                    </a>

                </div>

            </div>

        </div>

    </section>

    <!-- DESCRIPCION -->

    <section class="product-extra-description">

        <h2>

            Descripción del producto

        </h2>

        <p>

            <%= producto.descripcion || "Sin descripción disponible." %>

        </p>

    </section>

    <%- include("../partials/footer") %>

    <script>

    // =========================
    // CAMBIAR IMAGEN
    // =========================

    function cambiarImagen(src){

        document
            .getElementById("mainImage")
            .src = src;

    }

    // =========================
    // STOCK
    // =========================

    let talleSeleccionado = null;

    const stockMessage =
        document.getElementById(
            "stockMessage"
        );

    const addToCartBtn =
        document.getElementById(
            "addToCartBtn"
        );

    const sizeButtons =
        document.querySelectorAll(
            ".size-btn:not(.disabled-size)"
        );

    sizeButtons.forEach(btn => {

        btn.addEventListener(
            "click",
            () => {

                sizeButtons.forEach(b =>
                    b.classList.remove(
                        "active-size"
                    )
                );

                btn.classList.add(
                    "active-size"
                );

                talleSeleccionado =
                    btn.dataset.size;

                const stock =
                    Number(
                        btn.dataset.stock
                    );

                if(stock <= 0){

                    stockMessage.innerHTML =
                        "Sin stock";

                    stockMessage.className =
                        "stock-message no-stock";

                }

                else if(stock === 1){

                    stockMessage.innerHTML =
                        "Última unidad disponible";

                    stockMessage.className =
                        "stock-message low-stock";

                }

                else {

                    stockMessage.innerHTML =
                        `Stock disponible: ${stock}`;

                    stockMessage.className =
                        "stock-message in-stock";

                }

            }
        );

    });

    // =========================
    // ADD TO CART
    // =========================

    addToCartBtn.addEventListener(
        "click",
        () => {

            if(!talleSeleccionado){

                alert(
                    "Seleccioná un talle"
                );

                return;

            }

            const cantidad =
                Number(
                    document.getElementById(
                        "cantidad"
                    ).value
                );

            const producto = {

                id:
                    <%= producto.id %>,

                nombre:
                    "<%= producto.nombre %>",

                precio:
                    <%= producto.precio %>,

                talle:
                    talleSeleccionado,

                cantidad,

                imagen:
                    "<%= producto.imagenes[0] || '' %>"

            };

            let cart =
                JSON.parse(
                    localStorage.getItem(
                        "cart"
                    )
                ) || [];

            cart.push(producto);

            localStorage.setItem(
                "cart",
                JSON.stringify(cart)
            );

            actualizarContador();

            alert(
                "Producto agregado al carrito"
            );

        }
    );

    // =========================
    // CART COUNTER
    // =========================

    function actualizarContador(){

        const cart =
            JSON.parse(
                localStorage.getItem(
                    "cart"
                )
            ) || [];

        const total =
            cart.reduce(
                (acc,item)=>
                    acc + item.cantidad,
                0
            );

        const cartText =
            document.querySelector(
                '.header-right a[href="/carrito"]'
            );

        if(cartText){

            cartText.textContent =
                `Carrito (${total})`;

        }

    }

    actualizarContador();

</script>

</body>

</html>
